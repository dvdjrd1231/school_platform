# Copy to .env.local for development, and set the same variables in the Vercel
# dashboard (Settings -> Environment Variables) for deployment.

# ---- Database ---------------------------------------------------------------
# MongoDB Atlas connection string. The database name goes in the path.
MONGODB_URI="mongodb+srv://Vercel-Admin-atlas-coffee-feather:<db_password>@atlas-coffee-feather.fhwblhb.mongodb.net/?appName=atlas-coffee-feather"

# ---- Authentication ---------------------------------------------------------
# Generate with: openssl rand -base64 32
# Must be identical across all instances or sessions will not validate.
AUTH_SECRET="7dF9kLmP3xQ2vN8aR6tY4uW1zX5cB0hJ9mK2nL7pS4qV8eT1gH"

# Public URL of the deployment. Vercel sets this automatically in production;
# set it locally so callbacks resolve.
NEXTAUTH_URL="http://localhost:3000"

# ---- Bootstrap administrator ------------------------------------------------
# The initial admin account. On sign-in the app ensures this account exists as
# an active admin, so you never need to seed one manually. These env vars are
# the source of truth: change ADMIN_PASSWORD here and the admin's password
# updates on the next sign-in.
#
# ADMIN_USER MUST be an email address — it's what you type in the Email field.
ADMIN_USER="admin@maatk12.edu"
ADMIN_PASSWORD="change-me-to-a-strong-password"
# Optional display name (default "Administrator").
ADMIN_NAME="Administrator"

# ---- Real-time messaging (Pusher) -------------------------------------------
# From https://dashboard.pusher.com -> your app -> App Keys.
# Optional: without these the app still works, but messages arrive on refresh
# rather than instantly.
# WARNING: this file is COMMITTED to git. Put placeholders here only — real
# credentials belong in .env or .env.local, which are gitignored.
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="mt1"

# The NEXT_PUBLIC_ pair is sent to the browser. Use the same key and cluster as
# above. Never expose PUSHER_SECRET this way.
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="mt1"
